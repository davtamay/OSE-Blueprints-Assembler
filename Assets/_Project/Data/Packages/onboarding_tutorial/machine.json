        "training_bracket"
      ],
      "stepIds": [
        "step_orient",
        "step_select_inspect",
        "step_drag_place_beam",
        "step_use_hint",
        "step_place_bracket"
      ],
      "milestoneMessage": "You completed the onboarding tutorial!"
    }
  ],
