  "machine": {
    "id": "onboarding_tutorial",
    "name": "Onboarding Tutorial",
    "displayName": "Welcome Tutorial",
    "description": "A short guided tutorial that teaches navigation, selection, placement, hints, and step progression. Designed so a new user can complete it without prior knowledge.",
    "difficulty": "beginner",
    "estimatedBuildTimeMinutes": 3,
    "learningObjectives": [
      "Orient yourself in the assembly scene",
      "Select and inspect a part to read its info",
      "Drag or grab a part to place it at a target",
      "Request and read a hint",
      "Complete a multi-step assembly sequence"
    ],
    "recommendedMode": "tutorial",
    "entryAssemblyIds": [
      "assembly_onboarding"
    ],
    "prerequisiteNotes": [
      "No prior knowledge is required."
    ],
    "sourceReferences": []
  },
  "assemblies": [
    {
      "id": "assembly_onboarding",
      "name": "Onboarding Assembly",
      "description": "Walks the user through every core interaction one step at a time.",
      "machineId": "onboarding_tutorial",
      "subassemblyIds": [
        "subassembly_training_parts"
      ],
      "stepIds": [
        "step_orient",
        "step_select_inspect",
        "step_drag_place_beam",
        "step_use_hint",
        "step_place_bracket"
      ],
      "learningFocus": "Core interactions: observe, select, place, hint, progression."
    }
  ],
