      "function": "A practice bracket used to learn hint usage and a second placement.",
      "structuralRole": "Training part",
      "quantity": 1,
      "toolIds": [
        "tool_tape_measure"
      ],
      "assetRef": "assets/parts/training_bracket.glb",
      "searchTerms": [
        "training bracket",
