      "usageNotes": "Observe the part dimensions before placing."
    }
  ],
  "steps": [
    {
      "id": "step_orient",
      "name": "Orient yourself",
      "assemblyId": "assembly_onboarding",
      "subassemblyId": "subassembly_training_parts",
      "sequenceIndex": 1,
      "instructionText": "Welcome! Look around the scene. You can see parts on the left and right, and target markers in the center. The panels on screen show step instructions and part details. When you are ready, tap Continue.",
      "whyItMattersText": "Observing the workspace before acting helps you plan each placement.",
      "requiredPartIds": [],
      "relevantToolIds": [],
      "targetIds": [],
      "completionMode": "confirmation_only",
      "validationRuleIds": [],
      "hintIds": [],
      "effectTriggerIds": [],
      "allowAutoSnap": false,
      "allowSkip": false,
      "requiresConfirmation": true,
      "challengeFlags": {
        "penalizeHintUsage": false,
        "penalizeInvalidPlacement": false,
        "stricterToleranceAvailable": false
      },
      "eventTags": [
        "tutorial",
        "orient"
      ]
    },
    {
      "id": "step_select_inspect",
      "name": "Select and inspect a part",
      "assemblyId": "assembly_onboarding",
      "subassemblyId": "subassembly_training_parts",
      "sequenceIndex": 2,
      "instructionText": "Tap or click the orange beam on the left. Its name, material, and tool info will appear in the Part Info panel on the right. Select the part to unlock the Continue button.",
      "whyItMattersText": "Inspecting parts before placement ensures you pick the right piece for the job.",
      "requiredPartIds": [],
      "optionalPartIds": [
        "training_beam",
        "training_bracket"
      ],
      "relevantToolIds": [
        "tool_tape_measure"
      ],
      "targetIds": [],
      "completionMode": "confirmation_only",
      "validationRuleIds": [],
      "hintIds": [],
      "effectTriggerIds": [],
      "allowAutoSnap": false,
      "allowSkip": false,
      "requiresConfirmation": true,
      "challengeFlags": {
        "penalizeHintUsage": false,
        "penalizeInvalidPlacement": false,
        "stricterToleranceAvailable": false
      },
      "eventTags": [
        "tutorial",
        "select"
      ]
    },
    {
      "id": "step_drag_place_beam",
      "name": "Drag the beam to its target",
      "assemblyId": "assembly_onboarding",
      "subassemblyId": "subassembly_training_parts",
      "sequenceIndex": 3,
      "instructionText": "Drag or grab the orange beam and move it toward the transparent ghost shape in the center. When it is close enough it will snap into place automatically.",
      "whyItMattersText": "Placing parts at target positions is the core assembly action.",
      "requiredPartIds": [
        "training_beam"
      ],
      "relevantToolIds": [],
      "targetIds": [
        "target_beam_slot"
      ],
      "completionMode": "virtual_or_physical",
      "validationRuleIds": [
        "validation_beam_placement"
      ],
      "hintIds": [
        "hint_beam_placement"
      ],
      "effectTriggerIds": [],
      "allowAutoSnap": true,
      "allowSkip": false,
      "requiresConfirmation": false,
      "challengeFlags": {
        "penalizeHintUsage": false,
        "penalizeInvalidPlacement": false,
        "stricterToleranceAvailable": false
      },
      "eventTags": [
        "tutorial",
        "place"
      ]
    },
    {
      "id": "step_use_hint",
      "name": "Request a hint",
      "assemblyId": "assembly_onboarding",
      "subassemblyId": "subassembly_training_parts",
      "sequenceIndex": 4,
      "instructionText": "Sometimes you need guidance. Tap the Request Hint button below to see a hint. A message will appear in the panel and a bubble will point to the target. After reading the hint, tap Continue.",
      "whyItMattersText": "Hints guide you when placement is unclear — using them is encouraged during learning.",
      "requiredPartIds": [],
      "optionalPartIds": [
        "training_bracket"
      ],
      "relevantToolIds": [],
      "targetIds": [],
      "completionMode": "confirmation_only",
      "validationRuleIds": [],
      "hintIds": [
        "hint_bracket_guidance"
      ],
      "effectTriggerIds": [],
      "allowAutoSnap": false,
      "allowSkip": false,
      "requiresConfirmation": true,
      "challengeFlags": {
        "penalizeHintUsage": false,
        "penalizeInvalidPlacement": false,
        "stricterToleranceAvailable": false
      },
      "eventTags": [
        "tutorial",
        "hint"
      ]
    },
    {
      "id": "step_place_bracket",
      "name": "Place the bracket",
      "assemblyId": "assembly_onboarding",
      "subassemblyId": "subassembly_training_parts",
      "sequenceIndex": 5,
      "instructionText": "Now drag or grab the blue bracket and move it to its ghost target. Remember: each part only fits its own target — dropping the wrong part will flash red.",
      "whyItMattersText": "Placing the correct part at the correct target is how every assembly step works.",
      "requiredPartIds": [
        "training_bracket"
      ],
      "relevantToolIds": [],
