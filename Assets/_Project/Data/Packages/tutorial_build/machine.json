{
  "schemaVersion": "1.0.0",
  "packageVersion": "0.1.0",
  "machine": {
    "id": "tutorial_beam_alignment",
    "name": "Beam Alignment Tutorial",
    "displayName": "Tutorial Beam Alignment",
    "description": "A compact tutorial package that teaches how to compare a part against a target and move it into position.",
    "difficulty": "beginner",
    "estimatedBuildTimeMinutes": 5,
    "learningObjectives": [
      "Read a content-driven instruction step",
      "Identify a part from its metadata",
      "Understand how a target marker guides placement"
    ],
    "recommendedMode": "tutorial",
    "entryAssemblyIds": [
      "assembly_beam_alignment"
    ],
    "prerequisiteNotes": [
      "No prior assembly knowledge is required."
    ],
    "sourceReferences": [
      {
        "id": "tutorial_author_note",
        "type": "author_note",
        "title": "Internal preview training package",
        "notes": "Used to prove the phase 6 content pipeline before full machine runtime exists."
      }
    ]
  },
  "assemblies": [
    {
      "id": "assembly_beam_alignment",
      "name": "Beam Alignment Assembly",
      "description": "A minimal assembly that focuses on aligning one part with one target.",
      "machineId": "tutorial_beam_alignment",
      "subassemblyIds": [
        "subassembly_beam_target"
      ],
      "stepIds": [
        "step_inspect_beam",
        "step_move_beam_to_target"
      ],
      "learningFocus": "Reading part metadata and aligning a part to a target."
    }
  ],
  "subassemblies": [
    {
      "id": "subassembly_beam_target",
      "name": "Beam Target Unit",
      "assemblyId": "assembly_beam_alignment",
      "description": "Contains the single beam and the target used by the preview scene.",
      "partIds": [
        "tutorial_beam"
      ],
      "stepIds": [
        "step_inspect_beam",
        "step_move_beam_to_target"
      ],
      "milestoneMessage": "The beam is now aligned with its target."
    }
  ],
  "parts": [
    {
      "id": "tutorial_beam",
      "name": "Tutorial Beam",
      "displayName": "Orange Tutorial Beam",
      "category": "custom",
      "material": "Painted steel box tubing",
      "function": "Acts as the primary practice part for the first placement exercise.",
      "structuralRole": "Preview training part",
      "quantity": 1,
      "toolIds": [
        "tool_tape_measure",
        "tool_alignment_clamps"
      ],
      "assetRef": "assets/parts/tutorial_beam.glb",
      "searchTerms": [
        "tutorial beam",
        "alignment beam",
        "steel tubing"
      ],
      "allowPhysicalSubstitution": true,
      "defaultOrientationHint": "Keep the beam parallel to the target marker.",
      "tags": [
        "tutorial",
        "alignment"
      ]
    }
  ],
  "tools": [
    {
      "id": "tool_tape_measure",
      "name": "Tape Measure",
      "category": "measurement",
      "purpose": "Compare the beam length and spacing to the target marker.",
      "usageNotes": "Use this first while inspecting the beam."
    },
    {
      "id": "tool_alignment_clamps",
      "name": "Alignment Clamps",
      "category": "hand_tool",
      "purpose": "Hold the beam steady once it reaches the target area.",
      "usageNotes": "Use after the beam is centered on the target marker."
    }
  ],
  "steps": [
    {
      "id": "step_inspect_beam",
      "name": "Inspect the training beam",
      "assemblyId": "assembly_beam_alignment",
      "subassemblyId": "subassembly_beam_target",
      "sequenceIndex": 1,
      "instructionText": "Inspect the orange beam and compare it to the green target marker before moving anything.",
      "whyItMattersText": "This teaches the learner to read visual cues before attempting placement.",
      "requiredPartIds": [
        "tutorial_beam"
      ],
      "relevantToolIds": [
        "tool_tape_measure"
      ],
      "targetIds": [
        "target_beam_slot"
      ],
      "completionMode": "confirmation_only",
      "validationRuleIds": [
        "validation_beam_presence"
      ],
      "hintIds": [
        "hint_compare_beam_length"
      ],
      "effectTriggerIds": [
        "effect_preview_pulse"
      ],
      "allowAutoSnap": false,
      "allowSkip": false,
      "requiresConfirmation": true,
      "challengeFlags": {
        "penalizeHintUsage": false,
        "penalizeInvalidPlacement": false,
        "stricterToleranceAvailable": false
      },
      "eventTags": [
        "tutorial",
        "inspect"
      ]
    },
    {
      "id": "step_move_beam_to_target",
      "name": "Move the beam to the target",
      "assemblyId": "assembly_beam_alignment",
      "subassemblyId": "subassembly_beam_target",
      "sequenceIndex": 2,
      "instructionText": "Slide the orange beam toward the green target marker until it appears centered and square.",
      "whyItMattersText": "This proves the package can drive the same UI shell the runtime will later use for real steps.",
      "requiredPartIds": [
        "tutorial_beam"
      ],
      "relevantToolIds": [
        "tool_alignment_clamps"
      ],
      "targetIds": [
        "target_beam_slot"
      ],
      "completionMode": "virtual_or_physical",
      "validationRuleIds": [
        "validation_beam_alignment"
      ],
      "hintIds": [
        "hint_align_beam"
      ],
      "effectTriggerIds": [
        "effect_valid_alignment"
      ],
      "allowAutoSnap": true,
      "allowSkip": false,
      "requiresConfirmation": false,
      "challengeFlags": {
        "penalizeHintUsage": true,
        "penalizeInvalidPlacement": true,
        "stricterToleranceAvailable": true
      },
      "eventTags": [
        "tutorial",
        "place"
      ]
    }
  ],
  "validationRules": [
    {
      "id": "validation_beam_presence",
      "type": "confirmation",
      "expectedPartId": "tutorial_beam",
      "requiredPartIds": [
        "tutorial_beam"
      ],
      "failureMessage": "Inspect the tutorial beam before advancing."
    },
    {
      "id": "validation_beam_alignment",
      "type": "placement",
      "targetId": "target_beam_slot",
      "expectedPartId": "tutorial_beam",
      "positionToleranceMm": 8.0,
      "rotationToleranceDeg": 10.0,
      "failureMessage": "Move the beam closer to the green target marker.",
      "correctionHintId": "hint_align_beam"
    }
  ],
  "effects": [
    {
      "id": "effect_preview_pulse",
      "type": "placement_feedback",
      "fallbackRef": "assets/effects/preview_pulse.prefab",
      "triggerPolicy": "on_step_enter",
      "notes": "Draw attention to the target during the inspection step."
    },
    {
      "id": "effect_valid_alignment",
      "type": "success_feedback",
      "fallbackRef": "assets/effects/valid_alignment.prefab",
      "triggerPolicy": "on_success",
      "notes": "Would fire when the beam reaches the intended target."
    }
  ],
  "hints": [
    {
      "id": "hint_compare_beam_length",
      "type": "explanatory",
      "title": "Compare the beam to the target",
      "message": "Notice how the beam spans nearly the same width as the green target marker before moving it.",
      "targetId": "target_beam_slot",
      "priority": "medium"
    },
    {
      "id": "hint_align_beam",
      "type": "highlight",
      "title": "Aim for the center",
      "message": "Center the beam on top of the green target and keep its long edge parallel.",
      "targetId": "target_beam_slot",
      "partId": "tutorial_beam",
      "priority": "high"
    }
  ],
  "targets": [
    {
      "id": "target_beam_slot",
      "name": "Beam Target Marker",
      "anchorRef": "anchors/tutorial/beam_slot",
      "description": "The preview target used in the mechanics scene.",
      "associatedPartId": "tutorial_beam",
      "tags": [
        "tutorial",
        "alignment"
      ]
    }
  ],
  "challengeConfig": {
    "enabled": true,
    "trackTime": true,
    "trackRetries": true,
    "trackHintUsage": true,
    "leaderboardReady": false,
    "strictValidationModeAvailable": true
  },
  "assetManifest": {
    "modelRefs": [
      "assets/parts/tutorial_beam.glb"
    ],
    "effectRefs": [
      "assets/effects/preview_pulse.prefab",
      "assets/effects/valid_alignment.prefab"
    ],
    "uiRefs": [
      "ui/tutorial/beam_alignment"
    ]
  },
  "previewConfig": {
    "partPlacements": [
      {
        "partId":        "tutorial_beam",
        "startPosition": { "x": -2.0, "y": 0.55, "z": 0.0 },
        "startRotation": { "x": 0.0,  "y": 0.0,  "z": 0.0, "w": 1.0 },
        "startScale":    { "x": 1.45, "y": 0.28, "z": 0.38 },
        "color":         { "r": 0.94, "g": 0.55, "b": 0.18, "a": 1.0 },
        "playPosition":  { "x": -0.6, "y": 0.55, "z": 0.15 },
        "playRotation":  { "x": 0.0,  "y": 0.0,  "z": 0.0, "w": 1.0 },
        "playScale":     { "x": 1.35, "y": 0.28, "z": 0.38 }
      }
    ],
    "targetPlacements": [
      {
        "targetId": "target_beam_slot",
        "position": { "x": 0.0, "y": 0.04, "z": 0.0 },
        "rotation": { "x": 0.0, "y": 0.0,  "z": 0.0, "w": 1.0 },
        "scale":    { "x": 0.9, "y": 0.04, "z": 0.9 },
        "color":    { "r": 0.20, "g": 0.84, "b": 0.58, "a": 1.0 }
      }
    ]
  }
}
