  "hints": [
    {
      "id": "hint_stage_titan_aero_core",
      "type": "highlight",
      "title": "Orient Titan Aero with nozzle port accessible from below",
      "message": "Place the Titan Aero core with the motor and drive face pointing outward and the nozzle port accessible from below. This lets the blower and sensor-side parts attach without reorienting the module.",
      "targetId": "target_titan_aero_core_stage",
      "partId": "d3d_titan_aero_core",
      "priority": "medium"
    },
    {
      "id": "hint_attach_extruder_nozzle",
      "type": "highlight",
      "title": "Seat nozzle assembly square to core face",
      "message": "Push the nozzle assembly onto the Titan Aero core until it seats fully and sits square to the core face. Any tilt here will carry through to fan and sensor alignment.",
      "targetId": "target_extruder_nozzle_attach",
      "partId": "d3d_extruder_nozzle_assembly",
      "priority": "medium"
    },
    {
      "id": "hint_place_extruder_blower",
      "type": "highlight",
      "title": "Blower outlet faces toward nozzle tip",
      "message": "Place the 5015 blower onto the fan-side attachment point with the outlet directed toward the nozzle tip. Seat the body fully before tightening the mount screws.",
      "targetId": "target_extruder_blower_attach",
      "partId": "d3d_extruder_5015_blower",
      "priority": "medium"
    },
    {
      "id": "hint_secure_extruder_blower",
      "type": "tool_reminder",
      "title": "Small screwdriver for blower mount screws",
      "message": "Tighten both blower mount screws with the small screwdriver until snug. The blower body should not rock or shift when pushed sideways.",
      "toolId": "tool_screwdriver_small",
      "targetId": "target_extruder_blower_mount_a",
      "priority": "medium"
    },
    {
      "id": "hint_place_sensor_holder",
      "type": "highlight",
      "title": "Sensor holder mounts opposite the blower",
      "message": "Place the printed sensor holder on the sensor-side mount point of the nozzle module on the opposite face from the blower.",
      "targetId": "target_extruder_sensor_holder_attach",
      "partId": "d3d_extruder_sensor_holder",
      "priority": "medium"
    },
    {
      "id": "hint_secure_sensor_holder",
      "type": "tool_reminder",
      "title": "Lock holder before inserting sensor",
