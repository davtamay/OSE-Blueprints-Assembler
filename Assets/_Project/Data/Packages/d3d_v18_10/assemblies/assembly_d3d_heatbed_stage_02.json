  "hints": [
    {
      "id": "hint_y_bed_rods",
      "type": "highlight",
      "title": "Y-axis bed guide rods",
      "message": "Three rods run front-to-back connecting the front and back Z carriages. The bed platform slides along these rods as the printer moves the bed on the Y axis during a print.",
      "priority": "low"
    },
    {
      "id": "hint_mount_bed_guide_rods",
      "type": "highlight",
      "title": "Slide both bed rods through front and back Z carriages",
      "message": "Each bed guide rod threads through the hole in the Z-front carriage and the matching hole in the Z-back carriage. Thread two nuts onto each rod before inserting â€” the nuts sit on either side of the carriage to provide a flat support surface for the heated bed and to minimize heat transfer to the plastic. Push the rod ends flush with the outer edges of both carriages.",
      "targetId": "target_bed_rod_a_mount",
      "partId": "",
      "toolId": "",
      "priority": "medium"
    },
    {
      "id": "hint_place_bed_raisers",
      "type": "highlight",
      "title": "Thread 3 standoff raisers onto each rod; space them evenly",
      "message": "Thread the 6 bed raiser standoffs onto the two guide rods â€” 3 per rod. Space them evenly along the rod length so the heated bed will sit flat. The raisers provide the correct height gap between the Z carriage and the heated bed and allow wiring to pass freely beneath the bed surface.",
      "targetId": "target_bed_raisers_set",
      "partId": "",
      "toolId": "",
      "priority": "medium"
    },
    {
      "id": "hint_check_bed_platform_alignment",
      "type": "highlight",
      "title": "Confirm rods are flush, raisers level, and no side-to-side rock",
      "message": "QC checklist: (1) Rod ends are flush with the outer edges of both idler pieces â€” not protruding. (2) Two nuts are present on each rod. (3) Bolts are tightened enough to hold the rods but not so tight they deform the plastic. (4) The platform does not rock side to side when you apply light lateral pressure.",
      "targetId": "target_bed_platform_qc",
      "partId": "",
      "toolId": "",
      "priority": "medium"
    }
  ]
}
