  "hints": [
    {
      "id": "hint_stage_simplified_carriage",
      "type": "highlight",
      "title": "Set carriage with bracket-mount face up",
      "message": "Place the simplified carriage flat with the bracket-mounting face pointing upward. This face receives the Titan Aero mount bracket in the next step.",
      "targetId": "target_extruder_simplified_carriage_stage",
      "partId": "d3d_extruder_simplified_carriage",
      "priority": "medium"
    },
    {
      "id": "hint_place_mount_bracket",
      "type": "highlight",
      "title": "Bracket aligns to carriage fastener holes",
      "message": "Set the Titan Aero mount bracket against the carriage face and align the two fastener holes. The bracket should drop flat with light hand pressure. Do not force.",
      "targetId": "target_extruder_mount_bracket_attach",
      "partId": "d3d_extruder_mount_bracket",
      "priority": "medium"
    },
    {
      "id": "hint_secure_mount_bracket",
      "type": "tool_reminder",
      "title": "Tighten bracket bolts evenly side to side",
      "message": "Tighten the two bracket fasteners alternately, a quarter turn each side, so the bracket pulls down evenly. A tilted bracket will offset the nozzle from the carriage axis.",
      "toolId": "tool_allen_key_metric",
      "targetId": "target_extruder_mount_bracket_fastener_a",
      "priority": "high"
    },
    {
      "id": "hint_place_mount_top_plate",
      "type": "highlight",
      "title": "Top plate captures the bracket from above",
      "message": "Place the top plate over the bracket with both fastener holes aligned. The top plate locks the bracket against the carriage surface when its two fasteners are tightened.",
      "targetId": "target_extruder_mount_top_plate_attach",
      "partId": "d3d_extruder_mount_top_plate",
      "priority": "medium"
    },
    {
      "id": "hint_secure_mount_top_plate",
      "type": "tool_reminder",
      "title": "Fully tighten top-plate fasteners before mounting module",
      "message": "Tighten both top-plate fasteners fully with the 2.5 mm hex driver. The entire bracket stack must be locked solid before the completed nozzle module is mounted onto it.",
      "toolId": "tool_hex_driver_metric_small",
      "targetId": "target_extruder_mount_top_plate_fastener_a",
      "priority": "medium"
    },
    {
      "id": "hint_mount_nozzle_to_carriage",
      "type": "highlight",
      "title": "Keep nozzle module square when seating on bracket stack",
      "message": "Bring the completed Titan Aero nozzle module onto the bracket stack square and flat. The module rigid-mounts through the bracket. No fastener rotation is needed, just correct alignment.",
      "targetId": "target_extruder_module_to_carriage_mount",
      "priority": "medium"
    },
    {
      "id": "hint_check_carriage_mount_clearance",
      "type": "highlight",
      "title": "Confirm service access on all three extruder sides",
      "message": "Check the extruder body, nozzle exit, and sensor side in turn. Each must have enough open space that a technician could remove the sensor or nozzle after the carriage is fully integrated.",
      "targetId": "target_extruder_mount_clearance_body",
      "priority": "medium"
    }
  ]
}
