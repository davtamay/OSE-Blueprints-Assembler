    {
      "id": "hint_stage_heatbed_body",
      "type": "highlight",
      "title": "Center bed body under nozzle travel path",
      "message": "Place the heatbed body roughly centered under the nozzle travel area. The two snapbuckle retainers will hold it in position in the next two steps.",
      "targetId": "target_heatbed_body_mount",
      "partId": "d3d_heatbed_body",
      "priority": "medium"
    },
    {
      "id": "hint_place_snapbuckle_left",
      "type": "highlight",
      "title": "Left snapbuckle clicks into left bed edge",
      "message": "Press the left snapbuckle firmly onto the left side of the bed body until it clicks into the retainer channel. The fit should be firm with no visible gap.",
      "targetId": "target_heatbed_snapbuckle_left",
      "partId": "d3d_heatbed_snapbuckle_left",
      "priority": "medium"
    },
    {
      "id": "hint_place_snapbuckle_right",
      "type": "highlight",
      "title": "Right snapbuckle mirrors the left",
      "message": "Press the right snapbuckle onto the right side of the bed body until it clicks. The bed should now be retained symmetrically on both sides with equal pressure.",
      "targetId": "target_heatbed_snapbuckle_right",
      "partId": "d3d_heatbed_snapbuckle_right",
      "priority": "medium"
    },
    {
      "id": "hint_check_heatbed_clearance",
      "type": "highlight",
      "title": "Check bed centering and nozzle-to-bed clearance",
      "message": "Inspect both bed-to-frame margins. They should be roughly equal. Move the nozzle carriage across the full range and confirm the nozzle tip stays above the bed surface at every position.",
      "targetId": "target_heatbed_nozzle_clearance",
      "priority": "high"
    },
