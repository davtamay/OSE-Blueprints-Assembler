  "hints": [
    {
      "id": "hint_mount_control_panel",
      "message": "Align the control panel enclosure to the front-left face of the frame. The mounting tabs should sit flush against the frame bars before fastening.",
      "targetId": null,
      "partId": null,
      "type": "text"
    },
    {
      "id": "hint_install_ramps_board",
      "message": "Seat the RAMPS 1.4 board firmly into the control panel. The USB port and power screw terminals should face outward. Ensure no pins are bent when pressing the board down.",
      "targetId": null,
      "partId": null,
      "type": "text"
    },
    {
      "id": "hint_secure_control_panel",
      "message": "Thread M3 screws through the panel mounting tabs. Snug finger-tight first, then apply a quarter-turn with a screwdriver. Do not overtighten plastic tabs.",
      "targetId": null,
      "partId": null,
      "type": "text"
    },
    {
      "id": "hint_connect_psu_12v",
      "message": "The +12V line (red wire) connects to the V+ screw terminal on RAMPS. Strip 6mm of insulation, insert the bare end, and tighten the terminal screw until the wire does not pull free.",
      "targetId": null,
      "partId": null,
      "type": "text"
    },
    {
      "id": "hint_connect_psu_gnd",
      "message": "The ground line (black wire) connects to the GND screw terminal adjacent to V+. Polarity matters â€” reversing +12V and GND will damage the RAMPS board immediately.",
      "targetId": null,
      "partId": null,
      "type": "text"
    },
    {
      "id": "hint_connect_psu_atx_enable",
      "message": "Short the PS_ON pin (green wire) to a GND pin on the ATX connector to force the PSU on. Without this jumper the PSU will not supply power when switched on.",
      "targetId": null,
      "partId": null,
      "type": "text"
    },
    {
      "id": "hint_verify_psu_connections",
      "message": "Check all three PSU connections: V+ (red), GND (black), and the PS_ON enable jumper. Wiggle each wire gently â€” a properly seated terminal will not move.",
      "targetId": null,
      "partId": null,
      "type": "text"
    },
    {
      "id": "hint_connect_motor",
      "message": "Stepper motor connectors are 4-pin dupont. Orientation matters for motor direction but not for damage â€” if the axis runs backwards in firmware, reverse the connector.",
      "targetId": null,
      "partId": null,
      "type": "text"
    },
    {
      "id": "hint_connect_endstop",
      "message": "Endstop connectors are 2-pin dupont (signal + GND). Connect to the MIN port for the corresponding axis on RAMPS (X-MIN, Y-MIN, Z-MIN). Do not use the MAX ports for home endstops.",
      "targetId": null,
      "partId": null,
      "type": "text"
    },
    {
      "id": "hint_connect_heater_cartridge",
      "message": "The heater cartridge wires (red/white pair) connect to the E0 heater output on RAMPS (D10 terminal). Polarity does not matter for a resistive heater element.",
      "targetId": null,
      "partId": null,
      "type": "text"
    },
    {
      "id": "hint_connect_thermistor",
      "message": "The thermistor connects to the T0 pin header (2-pin, signal + GND). Polarity matters â€” reversing the thermistor will read ambient temperature as 300Â°C and trigger thermal runaway protection.",
      "targetId": null,
      "partId": null,
      "type": "text"
    },
    {
      "id": "hint_connect_extruder_fan",
      "message": "The part-cooling fan connects to the always-on 12V fan header (pins labelled FAN). If using a controlled fan, use the D9 PWM output instead.",
      "targetId": null,
      "partId": null,
      "type": "text"
    },
    {
      "id": "hint_route_cables_chain",
      "message": "Route all axis motor cables through the cable chain before securing the chain to the frame. Leave 30mm of slack at each axis end to allow full travel without tension.",
      "targetId": null,
      "partId": null,
      "type": "text"
    }
  ]
}
