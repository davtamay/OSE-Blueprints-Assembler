{
  "assemblies": [
    {
      "id": "assembly_d3d_y_right_bench",
      "name": "Y-Right Axis Bench Build",
      "description": "Assembles the Y-right axis module from individual parts using the same procedure as Y-left. Y-right and Z-Front share the same plastic piece type — build instructions are identical. Note the slight orientation differences in motor cable direction and long-bolt position. Produces a labeled Y-right axis module ready for frame mounting.",
      "machineId": "d3d_v18_10",
      "subassemblyIds": [
        "subassembly_y_right_idler_build",
        "subassembly_y_right_motor_build",
        "subassembly_y_right_rod_assembly",
        "subassembly_y_right_belt_threading"
      ],
      "stepIds": [
        "step_y_right_idler_insert_bolt",
        "step_y_right_idler_insert_bearings",
        "step_y_right_idler_align_halves",
        "step_y_right_idler_bolt",
        "step_y_right_motor_pulley",
        "step_y_right_motor_pulley_pop",
        "step_y_right_motor_half_nuts",
        "step_y_right_motor_belt_channel",
        "step_y_right_motor_close_halves",
        "step_y_right_motor_belt_test",
        "step_y_right_motor_screws",
        "step_y_right_motor_m6_bolts",
        "step_y_right_motor_dangle_test",
        "step_y_right_rods_into_idler",
        "step_y_right_idler_tighten_rods",
        "step_y_right_carriage_onto_rods",
        "step_y_right_motor_onto_rods",
        "step_y_right_rods_qc",
        "step_y_right_belt_large_hole",
        "step_y_right_belt_around_idler",
        "step_y_right_belt_small_hole",
        "step_y_right_belt_peg_orient",
        "step_y_right_belt_first_peg",
        "step_y_right_belt_second_peg",
        "step_y_right_belt_travel_test",
        "step_y_right_label_axis",
        "step_y_right_compose_axis",
        "step_qc_y_right_axis_bench"
      ],
      "dependencyAssemblyIds": [
        "assembly_d3d_frame",
        "assembly_d3d_batch_carriage_build"
      ],
      "learningFocus": "Same bench-build sequence as Y-left: carriage bearing shake and rod-slide tests, idler rod-hole alignment, motor pulley pop-check, rod threading order, belt routing and first peg locked. Note: long M6x30 bolt is in bottom-left of motor half-piece (not top), and motor cable plug faces the belt drive hole."
    }
  ],
  "subassemblies": [
    {
      "id": "subassembly_y_right_idler_build",
      "name": "Y-Right Idler Assembly",
      "assemblyId": "assembly_d3d_y_right_bench",
      "description": "Same procedure as Y-left idler. Orient idler with large rectangular hole to the left. Insert M6x30 screw into top hole so screw end faces you. Leave all frame-mount bolts loose.",
      "partIds": [
        "idler003"
      ],
      "stepIds": [
        "step_y_right_idler_insert_bolt",
        "step_y_right_idler_insert_bearings",
        "step_y_right_idler_align_halves",
        "step_y_right_idler_bolt"
      ],
      "milestoneMessage": "Y-right idler assembled. Frame-mount bolt left loose."
    },
    {
      "id": "subassembly_y_right_motor_build",
      "name": "Y-Right Motor Holder Assembly",
      "assemblyId": "assembly_d3d_y_right_bench",
      "description": "Same procedure as Y-left motor holder. Note: M6x30 bolt goes in bottom-left hole (right side of motor half-piece has belt drive). Motor cable plug faces belt drive hole opposite the long M6x30 bolt.",
      "partIds": [
        "motor003"
      ],
      "stepIds": [
        "step_y_right_motor_pulley",
        "step_y_right_motor_pulley_pop",
        "step_y_right_motor_half_nuts",
        "step_y_right_motor_belt_channel",
        "step_y_right_motor_close_halves",
        "step_y_right_motor_belt_test",
        "step_y_right_motor_screws",
        "step_y_right_motor_m6_bolts",
        "step_y_right_motor_dangle_test"
      ],
      "milestoneMessage": "Y-right motor holder assembled and dangle-tested."
    },
    {
      "id": "subassembly_y_right_rod_assembly",
      "name": "Y-Right Axis Rod Assembly",
      "assemblyId": "assembly_d3d_y_right_bench",
      "description": "Inserts rods into idler flush with bottom, slides carriage onto rods (long bolts closer to idler), pushes motor holder onto rods (motor facing carriage bolt heads). Tightens idler's two shorter bolts and re-checks rods flush.",
      "partIds": [
        "rod_007",
        "rod_008",
        "y2_bracket"
      ],
      "stepIds": [
        "step_y_right_rods_into_idler",
        "step_y_right_idler_tighten_rods",
        "step_y_right_carriage_onto_rods",
        "step_y_right_motor_onto_rods",
        "step_y_right_rods_qc"
      ],
      "milestoneMessage": "Y-right guide rods threaded through all three units with rods flush at idler."
    },
    {
      "id": "subassembly_y_right_belt_threading",
      "name": "Y-Right Belt Threading",
      "assemblyId": "assembly_d3d_y_right_bench",
      "description": "Routes belt through carriage large hole, around idler bearing via belt-catcher side (smaller hole with teeth), pulls through and threads onto first peg, locks peg. Second peg placed loosely. Label axis Y-Right.",
      "partIds": [
        "idler003"
      ],
      "stepIds": [
        "step_y_right_belt_large_hole",
        "step_y_right_belt_around_idler",
        "step_y_right_belt_small_hole",
        "step_y_right_belt_peg_orient",
        "step_y_right_belt_first_peg",
        "step_y_right_belt_second_peg",
        "step_y_right_belt_travel_test",
        "step_y_right_label_axis"
      ],
      "milestoneMessage": "Y-right axis complete: belt routed, first peg locked, axis labeled and QC checked.",
      "isAggregate": true
    },
    {
      "id": "subassembly_y_right_bench_unit",
      "name": "Y Right Complete Axis Unit",
      "assemblyId": "assembly_d3d_y_right_bench",
      "description": "The fully assembled y right axis unit, ready for staging. Contains all bench-built components: carriage, idler, motor holder, rods, and belt.",
      "partIds": [
        "y_right_carriage_half_a",
        "y_right_carriage_half_b",
        "idler003",
        "motor003",
        "rod_007",
        "rod_008",
        "y2_bracket"
      ],
      "stepIds": [
        "step_y_right_compose_axis"
      ],
      "isAggregate": true
    }
