      "subassemblyId": "subassembly_y_right_idler_build",
      "sequenceIndex": 143,
      "family": "Place",
      "instructionText": "Insert two bearing pieces one on top of the other onto the bolt, flanges facing outward (away from each other)."
    },
    {
      "id": "step_y_right_idler_align_halves",
      "name": "Align idler rod holes before closing",
      "assemblyId": "assembly_d3d_y_right_bench",
      "subassemblyId": "subassembly_y_right_idler_build",
      "sequenceIndex": 144,
      "family": "Confirm",
      "instructionText": "Hold the second idler half against the first and confirm the circular rod holes on both halves line up correctly before pressing them together."
    },
    {
      "id": "step_y_right_idler_bolt",
      "name": "Bolt idler halves and secure bearing",
      "assemblyId": "assembly_d3d_y_right_bench",
      "subassemblyId": "subassembly_y_right_idler_build",
      "sequenceIndex": 145,
      "family": "Use",
      "instructionText": "Secure the idler with an M6x18 bolt through the top and one M6x30 bolt in the belt-side hole. Tighten until firm."
    },
    {
      "id": "step_y_right_motor_pulley",
      "name": "Mount pulley on motor shaft with spacer",
      "assemblyId": "assembly_d3d_y_right_bench",
      "subassemblyId": "subassembly_y_right_motor_build",
      "sequenceIndex": 146,
      "family": "Place",
      "instructionText": "Rest the thin spacer on the motor housing, then seat the pulley on the shaft above it. Tighten the first set screw with an Allen key — the spacer keeps the pulley off the housing.",
      "removePersistentToolIds": [],
      "targetIds": [],
      "requiredPartIds": [ "motor003" ],
      "requiredToolActions": [],
      "taskOrder": [{"kind":"part","id":"motor003"}],
      "workingOrientation": {"subassemblyRotation":{"x":0,"y":0,"z":0},"subassemblyPositionOffset":{"x":0,"y":0,"z":0}}
  },
    {
      "id": "step_y_right_motor_pulley_pop",
      "name": "Lock pulley set screw until it pops",
      "assemblyId": "assembly_d3d_y_right_bench",
      "subassemblyId": "subassembly_y_right_motor_build",
      "sequenceIndex": 147,
      "family": "Use",
      "instructionText": "Remove the spacer. Tighten the second set screw as firmly as possible, pressing near the Allen key midpoint. A soft \"pop\" means fully seated. Whether or not you hear it, tighten as hard as you can."
    },
    {
      "id": "step_y_right_motor_half_nuts",
      "name": "Load motor holder half with nuts and M6x30 bolt",
      "assemblyId": "assembly_d3d_y_right_bench",
      "subassemblyId": "subassembly_y_right_motor_build",
      "sequenceIndex": 148,
      "family": "Place",
      "instructionText": "Orient the motor holder half with the rectangular belt channel facing you. Insert one M6x30 bolt and three nuts into the holes now — the motor will cover them and block access later."
    },
    {
      "id": "step_y_right_motor_belt_channel",
      "name": "Insert belt in motor holder channel",
      "assemblyId": "assembly_d3d_y_right_bench",
      "subassemblyId": "subassembly_y_right_motor_build",
      "sequenceIndex": 149,
      "family": "Place",
      "instructionText": "Insert the belt into the channel in the motor holder half-piece with the toothed side facing inward toward where the pulley will sit."
    },
    {
      "id": "step_y_right_motor_close_halves",
      "name": "Close motor holder halves together",
      "assemblyId": "assembly_d3d_y_right_bench",
      "subassemblyId": "subassembly_y_right_motor_build",
      "sequenceIndex": 150,
      "family": "Place",
      "instructionText": "Press the two motor holder halves together with the belt seated in the channel."
    },
    {
      "id": "step_y_right_motor_belt_test",
      "name": "Confirm belt runs smoothly on pulley",
      "assemblyId": "assembly_d3d_y_right_bench",
      "subassemblyId": "subassembly_y_right_motor_build",
      "sequenceIndex": 151,
      "family": "Confirm",
      "instructionText": "Hold the motor in position against the holder and give the belt a gentle pull — it should slide along the motor pulley. If it does not, reseat the belt in the channel."
    },
    {
      "id": "step_y_right_motor_screws",
      "name": "Attach motor with 4 M3x25 screws",
      "assemblyId": "assembly_d3d_y_right_bench",
      "subassemblyId": "subassembly_y_right_motor_build",
      "sequenceIndex": 152,
      "family": "Use",
      "instructionText": "Insert the first M3x25 motor screw and tighten 3/4 of the way. Insert the remaining three screws and tighten each the same way — leave slightly loose so the motor retains flex for belt tensioning later."
    },
    {
      "id": "step_y_right_motor_m6_bolts",
      "name": "Insert M6x18 bolts into motor holder",
      "assemblyId": "assembly_d3d_y_right_bench",
      "subassemblyId": "subassembly_y_right_motor_build",
      "sequenceIndex": 153,
      "family": "Use",
      "instructionText": "Insert M6x18 bolts into the three remaining motor holder holes and tighten each into the nuts with an electric drill."
    },
    {
      "id": "step_y_right_motor_dangle_test",
      "name": "Dangle test: motor holder hangs securely",
      "assemblyId": "assembly_d3d_y_right_bench",
      "subassemblyId": "subassembly_y_right_motor_build",
      "sequenceIndex": 154,
      "family": "Confirm",
      "instructionText": "Hold the complete motor assembly by one of its bolts. It should hang without wobble or separation. This confirms bolts are fully seated before rod insertion."
    },
    {
      "id": "step_y_right_rods_into_idler",
      "name": "Insert rods into idler, ends flush",
      "assemblyId": "assembly_d3d_y_right_bench",
      "subassemblyId": "subassembly_y_right_rod_assembly",
      "sequenceIndex": 155,
      "family": "Place",
      "instructionText": "Insert both guide rods into the completed idler piece. Rod ends must be flush against the bottom of the idler. If rods are hard to insert, loosen the idler bolts, slide rods in, then re-tighten.",
      "removePersistentToolIds": [],
      "targetIds": [],
      "requiredPartIds": [ "rod_007", "rod_008" ],
      "requiredToolActions": [],
      "taskOrder": [{"kind":"part","id":"rod_007"},
        {"kind":"part","id":"rod_008"}],
      "workingOrientation": {"subassemblyRotation":{"x":0,"y":0,"z":0},"subassemblyPositionOffset":{"x":0,"y":0,"z":0}}
  },
    {
      "id": "step_y_right_idler_tighten_rods",
      "name": "Tighten short idler bolts onto rods",
      "assemblyId": "assembly_d3d_y_right_bench",
      "subassemblyId": "subassembly_y_right_rod_assembly",
      "sequenceIndex": 156,
      "family": "Use",
      "instructionText": "Tighten the two shorter idler bolts with an electric drill to grip the rods firmly. Leave the longer bolt loose — it will be used to attach the axis to the frame."
    },
    {
      "id": "step_y_right_carriage_onto_rods",
      "name": "Slide carriage onto rods",
      "assemblyId": "assembly_d3d_y_right_bench",
      "subassemblyId": "subassembly_y_right_rod_assembly",
      "sequenceIndex": 157,
      "family": "Place",
      "instructionText": "Slide the completed carriage onto the rods with the long bolt ends closer to the idler. This orientation maximizes the travel distance.",
      "removePersistentToolIds": [],
      "targetIds": [],
      "requiredPartIds": [ "y2_bracket" ],
      "requiredToolActions": [],
      "taskOrder": [{"kind":"part","id":"y2_bracket"}],
      "workingOrientation": {"subassemblyRotation":{"x":0,"y":0,"z":0},"subassemblyPositionOffset":{"x":0,"y":0,"z":0}}
  },
    {
      "id": "step_y_right_motor_onto_rods",
      "name": "Push motor holder onto rods",
      "assemblyId": "assembly_d3d_y_right_bench",
      "subassemblyId": "subassembly_y_right_rod_assembly",
      "sequenceIndex": 158,
      "family": "Place",
      "instructionText": "Push the motor holder piece onto the rods so the motor faces the carriage bolt heads. Loosen bolts if needed to slide on, then re-tighten."
    },
    {
      "id": "step_y_right_rods_qc",
      "name": "QC: rods flush, carriage slides freely",
      "assemblyId": "assembly_d3d_y_right_bench",
      "subassemblyId": "subassembly_y_right_rod_assembly",
      "sequenceIndex": 159,
      "family": "Confirm",
      "instructionText": "Check that rod ends are still flush at the idler bottom. Slide the carriage the full rod length — it should move with only slight bearing resistance."
    },
    {
      "id": "step_y_right_belt_large_hole",
      "name": "Thread belt through large carriage hole",
      "assemblyId": "assembly_d3d_y_right_bench",
      "subassemblyId": "subassembly_y_right_belt_threading",
      "sequenceIndex": 160,
      "family": "Place",
      "instructionText": "Inspect the carriage: one belt hole is large and smooth, the other small and ribbed. Insert one belt end through the large smooth hole with the toothed side facing inward."
    },
    {
      "id": "step_y_right_belt_around_idler",
      "name": "Route belt around idler bearing",
      "assemblyId": "assembly_d3d_y_right_bench",
      "subassemblyId": "subassembly_y_right_belt_threading",
      "sequenceIndex": 161,
      "family": "Place",
      "instructionText": "Feed the belt around the bearing inside the idler. Tip: curve the belt slightly in the direction of travel first — it navigates around the bearing more easily."
    },
    {
      "id": "step_y_right_belt_small_hole",
      "name": "Thread belt back through small carriage hole",
      "assemblyId": "assembly_d3d_y_right_bench",
      "subassemblyId": "subassembly_y_right_belt_threading",
      "sequenceIndex": 162,
      "family": "Place",
      "instructionText": "Once the belt is around the idler bearing, pull it back through the smaller ribbed carriage hole."
    },
    {
      "id": "step_y_right_belt_peg_orient",
      "name": "Confirm belt peg orientation before locking",
      "assemblyId": "assembly_d3d_y_right_bench",
      "subassemblyId": "subassembly_y_right_belt_threading",
      "sequenceIndex": 163,
      "family": "Confirm",
      "instructionText": "Thread the belt end through a belt peg. Confirm: the foot of the peg faces away from the toothed side of the belt and away from the axis center. Wrong orientation prevents the peg from locking correctly."
    },
    {
      "id": "step_y_right_belt_first_peg",
      "name": "Lock first belt peg",
      "assemblyId": "assembly_d3d_y_right_bench",
      "subassemblyId": "subassembly_y_right_belt_threading",
      "sequenceIndex": 164,
      "family": "Use",
      "instructionText": "Insert the belt end approximately 3/4 inch into the small ribbed belt hole, then simultaneously insert the peg into the same hole and press firmly until it locks."
    },
    {
      "id": "step_y_right_belt_second_peg",
      "name": "Insert second peg loosely",
      "assemblyId": "assembly_d3d_y_right_bench",
      "subassemblyId": "subassembly_y_right_belt_threading",
      "sequenceIndex": 165,
      "family": "Place",
      "instructionText": "Insert the second peg directly across from the first. Hand-tighten the belt by pulling it through the first peg as much as you can easily. Leave the second peg loose — it will be fully tensioned after mounting to the frame."
    },
    {
      "id": "step_y_right_belt_travel_test",
      "name": "Travel test: carriage moves smoothly with belt",
      "assemblyId": "assembly_d3d_y_right_bench",
      "subassemblyId": "subassembly_y_right_belt_threading",
      "sequenceIndex": 166,
      "family": "Confirm",
      "instructionText": "Slide the carriage along the full rod length with the belt installed. It should move smoothly without binding. If it binds, check the belt is not twisted and both carriage holes are correctly threaded."
    },
    {
      "id": "step_y_right_label_axis",
      "name": "Label completed Y-Right Axis and set aside",
      "assemblyId": "assembly_d3d_y_right_bench",
      "subassemblyId": "subassembly_y_right_belt_threading",
      "sequenceIndex": 168,
      "family": "Confirm",
      "instructionText": "Use masking tape and a marker to label this assembly as \"Y-Right Axis\". Set it aside in a safe place. It is complete and ready for frame mounting."
    },
