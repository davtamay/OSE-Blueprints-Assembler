{
  "schemaVersion": "1.0.0",
  "packageVersion": "0.1.0",
  "machine": {
    "id": "onboarding_tutorial",
    "name": "Onboarding Tutorial",
    "displayName": "Welcome Tutorial",
    "description": "A short guided tutorial that teaches navigation, selection, placement, hints, and step progression. Designed so a new user can complete it without prior knowledge.",
    "difficulty": "beginner",
    "estimatedBuildTimeMinutes": 3,
    "learningObjectives": [
      "Orient yourself in the assembly scene",
      "Select and inspect a part to read its info",
      "Equip and use a tool on a highlighted target",
      "Drag or grab a part to place it at a target",
      "Request and read a hint",
      "Complete a multi-step assembly sequence"
    ],
    "recommendedMode": "tutorial",
    "entryAssemblyIds": [
      "assembly_onboarding"
    ],
    "introImageRef": "onboarding_tutorial/intro.png",
    "prerequisiteNotes": [
      "No prior knowledge is required."
    ],
    "sourceReferences": []
  },
  "assemblies": [
    {
      "id": "assembly_onboarding",
      "name": "Onboarding Assembly",
      "description": "Walks the user through every core interaction one step at a time.",
      "machineId": "onboarding_tutorial",
      "subassemblyIds": [
        "subassembly_training_parts"
      ],
      "stepIds": [
        "step_select_inspect",
        "step_drag_place_beam",
        "step_equip_tape_measure",
        "step_use_tape_measure",
        "step_place_bracket"
      ],
      "learningFocus": "Core interactions: observe, select, use tools, place, hint, progression."
    }
  ],
  "subassemblies": [
    {
      "id": "subassembly_training_parts",
      "name": "Training Parts",
      "assemblyId": "assembly_onboarding",
      "description": "Contains the two training parts used throughout the tutorial.",
      "partIds": [
        "training_beam",
        "training_bracket"
      ],
      "stepIds": [
        "step_select_inspect",
        "step_drag_place_beam",
        "step_equip_tape_measure",
        "step_use_tape_measure",
        "step_place_bracket"
      ],
      "milestoneMessage": "You completed the onboarding tutorial!"
    }
  ],
  "parts": [
    {
      "id": "training_beam",
      "name": "Training Beam",
      "displayName": "Training Beam",
      "category": "custom",
      "material": "Painted steel box tubing",
      "function": "A practice beam used to learn selection and placement.",
      "structuralRole": "Training part",
      "quantity": 1,
      "toolIds": [
        "tool_tape_measure"
      ],
      "assetRef": "training_beam.gltf",
      "searchTerms": [
        "training beam",
        "tutorial beam",
        "practice part"
      ],
      "allowPhysicalSubstitution": true,
      "defaultOrientationHint": "Keep the beam parallel to the floor.",
      "tags": [
        "tutorial",
        "onboarding"
      ]
    },
    {
      "id": "training_bracket",
      "name": "Training Bracket",
      "displayName": "Training Bracket",
      "category": "bracket",
      "material": "Steel",
      "function": "A practice bracket used to learn hint usage and a second placement.",
      "structuralRole": "Training part",
      "quantity": 1,
      "toolIds": [
        "tool_tape_measure"
      ],
      "assetRef": "training_bracket.gltf",
      "searchTerms": [
        "training bracket",
        "tutorial bracket",
        "practice bracket"
      ],
      "allowPhysicalSubstitution": true,
      "defaultOrientationHint": "Align the bracket face with the target marker.",
      "tags": [
        "tutorial",
        "onboarding"
      ]
    }
  ],
  "tools": [
    {
      "id": "tool_tape_measure",
      "name": "Tape Measure",
      "category": "measurement",
      "purpose": "Helps compare part size to target spacing.",
      "usageNotes": "Observe the part dimensions before placing.",
      "assetRef": "tool_tape_measure.gltf"
    }
  ],
  "steps": [
    {
      "id": "step_select_inspect",
      "name": "Select and inspect a part",
      "assemblyId": "assembly_onboarding",
      "subassemblyId": "subassembly_training_parts",
      "sequenceIndex": 1,
      "instructionText": "Tap or click the orange beam on the left. Its name, material, and tool info will appear in the Part Info panel on the right. The tutorial moves on as soon as the part is selected.",
      "whyItMattersText": "Inspecting parts before placement ensures you pick the right piece for the job.",
      "requiredPartIds": [],
      "optionalPartIds": [
        "training_beam"
      ],
      "relevantToolIds": [
        "tool_tape_measure"
      ],
      "targetIds": [],
      "completionType": "placement",
      "validationRuleIds": [],
      "hintIds": [],
      "effectTriggerIds": [],
      "allowSkip": false,
      "challengeFlags": {
        "penalizeHintUsage": false,
        "penalizeInvalidPlacement": false,
        "stricterToleranceAvailable": false
      },
      "eventTags": [
        "tutorial",
        "select"
      ]
    },
    {
      "id": "step_drag_place_beam",
      "name": "Drag the beam to its target",
      "assemblyId": "assembly_onboarding",
      "subassemblyId": "subassembly_training_parts",
      "sequenceIndex": 2,
      "instructionText": "Drag or grab the orange beam and move it toward the transparent ghost shape in the center. When it is close enough it will snap into place automatically.",
      "whyItMattersText": "Placing parts at target positions is the core assembly action.",
      "requiredPartIds": [
        "training_beam"
      ],
      "relevantToolIds": [],
      "targetIds": [
        "target_beam_slot"
      ],
      "completionType": "placement",
      "validationRuleIds": [
        "validation_beam_placement"
      ],
      "hintIds": [
        "hint_beam_placement"
      ],
      "effectTriggerIds": [],
      "allowSkip": false,
      "challengeFlags": {
        "penalizeHintUsage": false,
        "penalizeInvalidPlacement": false,
        "stricterToleranceAvailable": false
      },
      "eventTags": [
        "tutorial",
        "place"
      ]
    },
    {
      "id": "step_equip_tape_measure",
      "name": "Equip the tape measure",
      "assemblyId": "assembly_onboarding",
      "subassemblyId": "subassembly_training_parts",
      "sequenceIndex": 3,
      "instructionText": "Open Tools and select Tape Measure. The tutorial will continue automatically once it is equipped.",
      "whyItMattersText": "Many blueprint steps require specific tools before you can continue.",
      "requiredPartIds": [],
      "optionalPartIds": [
        "training_bracket"
      ],
      "relevantToolIds": [
        "tool_tape_measure"
      ],
      "targetIds": [],
      "completionType": "tool_action",
      "validationRuleIds": [],
      "hintIds": [
        "hint_equip_tape_measure"
      ],
      "effectTriggerIds": [],
      "requiredToolActions": [
        {
          "id": "action_confirm_tape_measure_equipped",
          "toolId": "tool_tape_measure",
          "actionType": "measure",
          "requiredCount": 1,
          "successMessage": "Tape measure equipped.",
          "failureMessage": "Equip Tape Measure from Tools."
        }
      ],
      "allowSkip": false,
      "challengeFlags": {
        "penalizeHintUsage": false,
        "penalizeInvalidPlacement": false,
        "stricterToleranceAvailable": false
      },
      "eventTags": [
        "tutorial",
        "tool",
        "equip"
      ]
    },
    {
      "id": "step_use_tape_measure",
      "name": "Use the tape measure tool",
      "assemblyId": "assembly_onboarding",
      "subassemblyId": "subassembly_training_parts",
      "sequenceIndex": 4,
      "instructionText": "With Tape Measure equipped, find the floating pulsing orb above the bracket ghost target, move the tool cursor over it, then tap or click once to record a measurement pass.",
      "whyItMattersText": "This teaches using tools on specific targets before placing the next part.",
      "requiredPartIds": [],
      "optionalPartIds": [
        "training_bracket"
      ],
      "relevantToolIds": [
        "tool_tape_measure"
      ],
      "targetIds": [
        "target_bracket_slot"
      ],
      "completionType": "tool_action",
      "validationRuleIds": [],
      "hintIds": [
        "hint_use_tape_measure"
      ],
      "effectTriggerIds": [],
      "requiredToolActions": [
        {
          "id": "action_measure_bracket_target",
          "toolId": "tool_tape_measure",
          "actionType": "measure",
          "targetId": "target_bracket_slot",
          "requiredCount": 1,
          "successMessage": "Measurement recorded on the bracket target.",
          "failureMessage": "Equip the tape measure, then tap or click the pulsing marker at the bracket target."
        }
      ],
      "allowSkip": false,
      "challengeFlags": {
        "penalizeHintUsage": false,
        "penalizeInvalidPlacement": false,
        "stricterToleranceAvailable": false
      },
      "eventTags": [
        "tutorial",
        "tool",
        "measure"
      ]
    },
    {
      "id": "step_place_bracket",
      "name": "Place the bracket",
      "assemblyId": "assembly_onboarding",
      "subassemblyId": "subassembly_training_parts",
      "sequenceIndex": 5,
      "instructionText": "Now drag or grab the blue bracket and move it to its ghost target. Remember: each part only fits its own target — dropping the wrong part will flash red.",
      "whyItMattersText": "Placing the correct part at the correct target is how every assembly step works.",
      "requiredPartIds": [
        "training_bracket"
      ],
      "relevantToolIds": [],
      "targetIds": [
        "target_bracket_slot"
      ],
      "completionType": "placement",
      "validationRuleIds": [
        "validation_bracket_placement"
      ],
      "hintIds": [
        "hint_bracket_guidance"
      ],
      "effectTriggerIds": [],
      "allowSkip": false,
      "challengeFlags": {
        "penalizeHintUsage": false,
        "penalizeInvalidPlacement": false,
        "stricterToleranceAvailable": false
      },
      "eventTags": [
        "tutorial",
        "place"
      ]
    }
  ],
  "validationRules": [
    {
      "id": "validation_beam_placement",
      "type": "placement",
      "targetId": "target_beam_slot",
      "expectedPartId": "training_beam",
      "positionToleranceMm": 50.0,
      "rotationToleranceDeg": 30.0,
      "failureMessage": "Move the beam closer to the ghost target.",
      "correctionHintId": "hint_beam_placement"
    },
    {
      "id": "validation_bracket_placement",
      "type": "placement",
      "targetId": "target_bracket_slot",
