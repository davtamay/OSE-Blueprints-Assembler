# IDE settings
.vs/
.vscode/
.idea/
.fleet/
.vsconfig

# OS metadata
.DS_Store
Thumbs.db
Desktop.ini

# Build tools (download locally, not tracked)
Tools/*.exe

# Local environment files
.env
.env.*
!.env.example

# Backup files
*.bak

# Python bytecode (offline validation scripts generate these transiently)
__pycache__/
*.pyc
*.pyo

# Agent-generated audit cache (regenerated from machine.json on demand)
audit-index.json
